rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Catch-All Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Common Helpers
    function incoming() {
      return request.resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_-]+$');
    }

    // Validation Blueprints
    function isValidNote(data) {
      return data.keys().hasAll(['id', 'text', 'color', 'x', 'y', 'createdAt'])
        && data.keys().size() >= 6 && data.keys().size() <= 9
        && data.id is string && data.id.size() <= 128
        && data.text is string && data.text.size() <= 1000
        && data.color is string && data.color.size() <= 200
        && (data.x is int || data.x is float)
        && (data.y is int || data.y is float)
        && data.createdAt is string
        && (!data.keys().hasAll(['musicTitle']) || (data.musicTitle is string && data.musicTitle.size() <= 200))
        && (!data.keys().hasAll(['youtubeUrl']) || (data.youtubeUrl is string && data.youtubeUrl.size() <= 1000))
        && (!data.keys().hasAll(['noteEmoji']) || (data.noteEmoji is string && data.noteEmoji.size() <= 100));
    }

    function isValidPhoto(data) {
      return data.keys().hasAll(['id', 'url', 'title', 'createdAt', 'downloads'])
        && data.keys().size() >= 5 && data.keys().size() <= 9
        && data.id is string && data.id.size() <= 128 && data.url is string && data.url.size() <= 20971520
        && data.title is string && data.title.size() <= 200
        && data.createdAt is string
        && data.downloads is int
        && (!data.keys().hasAll(['description']) || (data.description is string && data.description.size() <= 1000))
        && (!data.keys().hasAll(['type']) || (data.type is string && data.type.size() <= 20))
        && (!data.keys().hasAll(['reactions']) || data.reactions is map)
        && (!data.keys().hasAll(['comments']) || data.comments is list);
    }

    function isValidFile(data) {
      return data.keys().hasAll(['id', 'name', 'type', 'size', 'url', 'title', 'createdAt', 'downloads'])
        && data.keys().size() == 8
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 255
        && data.type is string && data.type.size() <= 128
        && data.size is int && data.size <= 1048576
        && data.url is string && data.url.size() <= 1048576
        && data.title is string && data.title.size() <= 200
        && data.createdAt is string
        && data.downloads is int;
    }

    // 2. Match note documents
    match /notes/{noteId} {
      allow read: if true;
      allow create: if isValidId(noteId) && isValidNote(incoming());
      allow update: if isValidId(noteId) && isValidNote(incoming());
      allow delete: if true;
    }

    // 3. Match photos album documents
    match /photos/{photoId} {
      allow read: if true;
      allow create: if isValidId(photoId) && isValidPhoto(incoming());
      allow update: if isValidId(photoId) && isValidPhoto(incoming());
      allow delete: if true;
    }

    // 4. Match rams_files document records
    match /rams_files/{fileId} {
      allow read: if true;
      allow create: if isValidId(fileId) && isValidFile(incoming());
      allow update: if isValidId(fileId) && isValidFile(incoming());
      allow delete: if true;
    }
  }
}
